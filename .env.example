# Root env for docker-compose (optional overrides). Each app also has its own .env.example.
JWT_ACCESS_SECRET=dev_access_secret_change_me
JWT_REFRESH_SECRET=dev_refresh_secret_change_me

# AI: OpenAI (GPT) is the only provider. Without a key, AI features fall back to
# deterministic templates so the app still runs.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# --- Search (F3 AI-HR job search) ---
# SEARCH_PROVIDER = mock | tavily | brave (default: mock — zero credentials needed)
SEARCH_PROVIDER=mock
TAVILY_API_KEY=
BRAVE_API_KEY=

# --- Billing ---
# CareerOS is free-first. Keep false to disable all plan gating.
BILLING_ENABLED=false

