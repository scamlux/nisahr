NEXT_PUBLIC_API_URL=http://localhost:4000/api
# Keep false: CareerOS is free-first (hides plans/upgrade UI)
NEXT_PUBLIC_BILLING_ENABLED=false
# MVP mode is ON by default (lean single-path product). Set to false to
# restore the full feature set (model picker, multiple roadmaps, Learning Hub,
# Psych Test). Anything other than the literal "false" keeps MVP mode on.
NEXT_PUBLIC_MVP_MODE=true
