# --- Database ---
# Runtime connection. On Vercel/serverless this MUST be the Supabase transaction
# pooler (port 6543) with ?pgbouncer=true&connection_limit=1
DATABASE_URL="postgresql://careeros:careeros@localhost:5432/careeros?schema=public"
# Direct (non-pooled, port 5432) connection used only by `prisma migrate`.
# Locally set it to the same value as DATABASE_URL.
DIRECT_URL="postgresql://careeros:careeros@localhost:5432/careeros?schema=public"

# --- Server ---
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# --- Auth ---
JWT_ACCESS_SECRET=dev_access_secret_change_me
JWT_REFRESH_SECRET=dev_refresh_secret_change_me
JWT_ACCESS_TTL=900s
JWT_REFRESH_TTL=7d

# --- AI ---
# AI_PROVIDER = mock | openai | gemini | groq | openrouter (default: mock — zero credentials needed)
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/auto

# --- Search (F3 AI-HR job search) ---
# SEARCH_PROVIDER = mock | tavily | brave (default: mock — zero credentials needed)
SEARCH_PROVIDER=mock
TAVILY_API_KEY=
BRAVE_API_KEY=

# --- Billing ---
# CareerOS is free-first. Keep false to disable all plan gating.
BILLING_ENABLED=false


# --- Web app URL (used for links inside emails & Stripe redirects) ---
APP_URL=http://localhost:3000

# --- Transactional email (F7 email verification) ---
# Real email is sent via Resend when RESEND_API_KEY is set; otherwise the
# verification link is logged (dev). MAIL_ENABLED=true also makes new signups
# start unverified. Leave RESEND_API_KEY blank for the zero-key demo.
MAIL_ENABLED=false
RESEND_API_KEY=
MAIL_FROM="CareerOS <onboarding@resend.dev>"

# --- Google OAuth (F7 real sign-in) ---
# When both CLIENT_ID and CLIENT_SECRET are set, real Google OAuth is used and
# the zero-key "mock Google" login is automatically disabled.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback
# Force-enable the mock Google login even with real creds (local testing only).
AUTH_DEV_BYPASS=false

# --- Stripe billing (real PREMIUM upgrades) ---
# When SECRET_KEY and PRICE_PREMIUM are set, PREMIUM upgrades go through Stripe
# Checkout. Also set BILLING_ENABLED=true to turn on plan gating.
STRIPE_SECRET_KEY=
STRIPE_PRICE_PREMIUM=

# --- Swagger ---
# Disable in production to avoid cold-start cost.
SWAGGER_ENABLED=true
