# --- Database ---
# Runtime connection. On Vercel/serverless this MUST be the Supabase transaction
# pooler (port 6543) with ?pgbouncer=true&connection_limit=1
DATABASE_URL="postgresql://careeros:careeros@localhost:5432/careeros?schema=public"
# Direct (non-pooled, port 5432) connection used only by `prisma migrate`.
# Locally set it to the same value as DATABASE_URL.
DIRECT_URL="postgresql://careeros:careeros@localhost:5432/careeros?schema=public"

# --- Server ---
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# --- Auth ---
JWT_ACCESS_SECRET=dev_access_secret_change_me
JWT_REFRESH_SECRET=dev_refresh_secret_change_me
JWT_ACCESS_TTL=900s
JWT_REFRESH_TTL=7d

# --- Google OAuth (F7) ---
# Leave BOTH client vars empty to use the zero-key demo sign-in (each person
# enters a name/email and gets their OWN persistent account).
# Set all three to enable the real "Continue with Google" popup. The redirect
# URI must be registered in Google Cloud console and point at the WEB app:
#   https://<your-web-domain>/auth/callback   (local: http://localhost:3000/auth/callback)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback
# Force-allow the mock endpoint even when real Google is configured (dev only).
AUTH_DEV_BYPASS=false

# --- AI ---
# AI_PROVIDER = mock | openai | gemini | groq | openrouter (default: mock — zero credentials needed)
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/auto

# --- Search (F3 AI-HR job search) ---
# SEARCH_PROVIDER = mock | tavily | brave (default: mock — zero credentials needed)
SEARCH_PROVIDER=mock
TAVILY_API_KEY=
BRAVE_API_KEY=

# --- Billing ---
# CareerOS is free-first. Keep false to disable all plan gating.
BILLING_ENABLED=false

