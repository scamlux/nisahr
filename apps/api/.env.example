# --- Database ---
# Local dev: a single direct Postgres connection is fine for both.
DATABASE_URL="postgresql://careeros:careeros@localhost:5432/careeros?schema=public"
DIRECT_URL="postgresql://careeros:careeros@localhost:5432/careeros?schema=public"
#
# Production (Vercel serverless + Supabase):
#   DATABASE_URL → transaction pooler (port 6543), used at runtime by the app.
#   DIRECT_URL   → direct/session connection (port 5432), used only by
#                  `prisma migrate deploy` / `prisma db push` (DDL can't run on the pooler).
# DATABASE_URL="postgresql://postgres.<ref>:<pw>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# DIRECT_URL="postgresql://postgres.<ref>:<pw>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# --- Server ---
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# --- Auth ---
JWT_ACCESS_SECRET=dev_access_secret_change_me
JWT_REFRESH_SECRET=dev_refresh_secret_change_me
JWT_ACCESS_TTL=900s
JWT_REFRESH_TTL=7d

# --- AI ---
# AI_PROVIDER = mock | openai | gemini | groq | openrouter (default: mock — zero credentials needed)
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/auto

# --- Search (F3 AI-HR job search) ---
# SEARCH_PROVIDER = mock | tavily | brave (default: mock — zero credentials needed)
SEARCH_PROVIDER=mock
TAVILY_API_KEY=
BRAVE_API_KEY=

# --- Billing ---
# CareerOS is free-first. Keep false to disable all plan gating.
BILLING_ENABLED=false

